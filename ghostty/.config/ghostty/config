# Font
font-family = JetBrainsMono Nerd Font
font-size = 14

# Theme
theme = Catppuccin Mocha

# Window
window-padding-x = 8
window-padding-y = 4
window-decoration = true
macos-titlebar-style = tabs

# Cursor
cursor-style = block
cursor-style-blink = false
shell-integration-features = cursor,sudo,title
custom-shader = shaders/cursor_tail.glsl

# Clipboard
copy-on-select = clipboard
clipboard-paste-protection = false

# Mouse
mouse-hide-while-typing = true

# Keyboard
macos-option-as-alt = left
# Send proper Alt+Arrow CSI sequences instead of \ef/\eb (word-jump sequences)
# which Zellij intercepts as Alt+f/b and triggers unintended actions.
keybind = opt+right=text:\x1b[1;3C
keybind = opt+left=text:\x1b[1;3D

# Misc
confirm-close-surface = false
